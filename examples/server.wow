# server.wow — a basic web server in wow
# Run with: wow build server.wow --target node

lao express

banao shuru() {
    bol "Server shuru ho raha hai port 3000 par..."
    server(3000)
}

rasta GET "/" {
    jawab "Salam Duniya! wow web server chal raha hai."
}

rasta GET "/hisaab" {
    numbers = [1, 5, 3, 8, 2, 9]
    total = jama(numbers)
    jawab "Jama: {total}"
}
