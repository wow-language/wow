# koshish.wow — ghalti pakadna (catching errors)
# Chalayein:  wow run koshish.wow      ya      wow run koshish.wow --target node

banao mehfooz_taqseem(a, b) {
    koshish {
        bhejo a / b
    } pakro ghalti {
        likho "Ghalti pakdi: {ghalti}"
        bhejo khali
    }
}

likho "10 / 2 = {mehfooz_taqseem(10, 2)}"
likho "10 / 0 = {mehfooz_taqseem(10, 0)}"
likho "Program theek se khatam hua."
