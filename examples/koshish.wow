# koshish.wow — ghalti pakadna (catching errors)
# Chalayein:  wow run koshish.wow      ya      wow run koshish.wow --target node

banao mehfooz_taqseem(a, b) {
    koshish {
        bhejo a / b
    } pakro ghalti {
        bol "Ghalti pakdi: {ghalti}"
        bhejo khali
    }
}

bol "10 / 2 = {mehfooz_taqseem(10, 2)}"
bol "10 / 0 = {mehfooz_taqseem(10, 0)}"
bol "Program theek se khatam hua."
